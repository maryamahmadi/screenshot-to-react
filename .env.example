# Copy to .env.local and fill in.
# The app runs fully in MOCK MODE with no keys set: the AI provider adapter
# falls back to a deterministic mock generator. Add the Anthropic key later to
# switch to real Claude output with no code changes.

# --- AI provider (optional; leave unset for mock mode) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (required for auth/history) ---
# Project URL, e.g. https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (sb_publishable_...) - safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key (sb_secret_...) - backend only, bypasses RLS. Never expose/commit.
SUPABASE_SECRET_KEY=
