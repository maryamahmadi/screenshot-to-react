# Copy to .env.local and fill in.
# The app runs fully in MOCK MODE with no keys set: the AI provider adapter
# falls back to a deterministic mock generator. Add the Anthropic key later to
# switch to real Claude output with no code changes.

# --- AI provider (optional; leave unset for mock mode) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (required once auth/history are wired up) ---
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
